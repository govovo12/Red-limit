          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">int count = props.get(&quot;shared_oid_count&quot;) as int
(0..&lt;count).each { i -&gt;
    def value = props.get(&quot;shared_oid_${i}&quot;)
    vars.put(&quot;shared_oid_${i}&quot;, value)
    log.info(&quot;✅ 灌進 vars: shared_oid_${i} = ${value}&quot;)
}
vars.put(&quot;shared_oid_count&quot;, count.toString())
log.info(&quot;📦 重灌變數 Thread ID = ${Thread.currentThread().getId()}&quot;)
log.info(&quot;🔁 載入 shared_oid_count = ${vars.get(&apos;shared_oid_count&apos;)}&quot;)
log.info(&quot;🔍 Thread ID = &quot; + Thread.currentThread().getId())




</stringProp>
