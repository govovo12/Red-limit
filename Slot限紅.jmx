          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">try {
    // 取得目前迴圈 index（每圈執行 0, 1, 2...）
    int i = Integer.parseInt(vars.get(&quot;LoopController__idx&quot;))

    // 從 props（全域變數）中取得對應的 OID
    String oid = props.get(&quot;shared_oid_&quot; + i)

    if (oid != null) {
        vars.put(&quot;oid&quot;, oid)  // 存回 Thread 本地變數給後續使用
        log.info(&quot;🔁 第 &quot; + i + &quot; 次迴圈，使用 shared_oid_&quot; + i + &quot; = &quot; + oid)
    } else {
        log.warn(&quot;⚠️ shared_oid_&quot; + i + &quot; 不存在，可能超出範圍或未正確傳值&quot;)
    }
} catch (Exception e) {
    log.error(&quot;❌ Loop index 或 props.get 錯誤&quot;, e)
}

</stringProp>
          </JSR223Sampler>
