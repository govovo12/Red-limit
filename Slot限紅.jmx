          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper

// 取得 HTTP 回應內容
def body = prev.getResponseDataAsString()
log.info(&quot;📥 原始回應：\n&quot; + body)

def json = new JsonSlurper().parseText(body)
def oidList = []

// 解析 JSON 並篩選 game_code 以 slot 開頭的 oid
json.data.each { key, value -&gt;
    if (value instanceof Map &amp;&amp; value.containsKey(&quot;game_code&quot;) &amp;&amp; value.game_code.toLowerCase().startsWith(&quot;slot&quot;)) {
        if (value.containsKey(&quot;oid&quot;)) {
            oidList &lt;&lt; value.oid
        }
    }
}

// 寫入 ForEach 可用的變數（vars 用於當前 thread，props 用於跨 Thread Group）
oidList.eachWithIndex { oid, idx -&gt;
    def key = &quot;shared_oid_${idx}&quot;
    vars.put(key, oid.toString())   // 當前 Thread 可用
    props.put(key, oid.toString())  // 跨 Thread 可用
}
vars.put(&quot;shared_oid_count&quot;, oidList.size().toString())
props.put(&quot;shared_oid_count&quot;, oidList.size().toString())

log.info(&quot;🎯 篩選後 slot oid 共 ${oidList.size()} 筆：${oidList}&quot;)






















</stringProp>
          </JSR223PostProcessor>
