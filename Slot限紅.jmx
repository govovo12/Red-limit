              <stringProp name="script">import groovy.json.JsonSlurper

def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)

def count = 0

json.data.each { key, entry -&gt;
    def gameCode = entry.game_code
    if (gameCode != null &amp;&amp; gameCode.startsWith(&quot;Slot&quot;)) {
        count++
    }
}

log.info(&quot;開頭為 &apos;Slot&apos; 的 game_code 數量為：${count}&quot;)
vars.put(&quot;slot_game_code_count&quot;, count.toString())





















