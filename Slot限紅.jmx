          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="從RTP取OID">
            <stringProp name="HTTPSampler.domain">privatebeta2-cms.lezdemo.com</stringProp>
