          <stringProp name="HTTPSampler.path">/api_beta/api/v1/cms/riskmgt/game_risk_info/list?risk_label_list=DEFAULT&amp;pf_sub_pf_id=pmyr_MYRS</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
