                  <hashTree/>
                  <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Max PostProcessor">
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="script">import groovy.json.JsonSlurper  // 引入 JsonSlurper 類

try {
    // 獲取當前請求的回應內容
    def body = prev.getResponseDataAsString()  // 使用 prev.getResponseDataAsString() 來獲取 body

    // 檢查 body 是否為 null 或空
    if (body == null || body.trim().isEmpty()) {
        log.error(&quot;Response body is empty!&quot;)
    } else {
        log.info(&quot;Response body: &quot; + body)  // 打印 response body，方便調試

        // 解析 JSON 內容
        def json = new JsonSlurper().parseText(body)

        // 檢查 json.bet_info 是否存在
        if (json?.bet_info) {
            // 提取 bet_info 中的 bet_value, bet_lines, bet_coin, bet_level，並處理未成功獲取值的情況
            def a = json.bet_info?.bet_value?.get(0) ?: &apos;Fail&apos;  // 若無值則回 &apos;Fail&apos;
            def b = json.bet_info?.bet_lines?.get(0) ?: &apos;Fail&apos;  // 若無值則回 &apos;Fail&apos;
            def c = json.bet_info?.bet_coin?.get(0) ?: &apos;Fail&apos;   // 若無值則回 &apos;Fail&apos;
            def d = json.bet_info?.bet_level?.get(0) ?: &apos;Fail&apos;  // 若無值則回 &apos;Fail&apos;

            // 輸出到 LOG 中
            log.info(&quot;a = &quot; + a)  // 打印 a 的值
            log.info(&quot;b = &quot; + b)  // 打印 b 的值
            log.info(&quot;c = &quot; + c)  // 打印 c 的值
            log.info(&quot;d = &quot; + d)  // 打印 d 的值

            // 計算 max 值，若有 &apos;Fail&apos; 則 max 也設為 &apos;Fail&apos;
            def max
            if (a == &apos;Fail&apos; || b == &apos;Fail&apos; || c == &apos;Fail&apos; || d == &apos;Fail&apos;) {
                max = &apos;Fail&apos;
            } else {
                // 如果 a、b、c 和 d 都是有效的數字，則計算它們的乘積
                max = a * b * c * d
            }

            // 儲存 max 結果到 JMeter 變數
            vars.put(&quot;max&quot;, max.toString())  // 儲存計算結果

            // 輸出 max 結果
            log.info(&quot;max = &quot; + max)

            // 獲取當前 oidx 變數
            def oidx = vars.get(&quot;oidx&quot;)  // 獲取當前的 OIDX

            // 確保 oidx 已正確設置並打印
            if (oidx == null) {
                log.error(&quot;oidx is NOT set correctly!&quot;)
            } else {
                log.info(&quot;oidx = &quot; + oidx)  // 打印 oidx 的值，方便調試
            }

            // 如果 max &gt; 0.1 或是 max &lt; 0.1，顯示錯誤並顯示 oidx 和 max
            if (max != &apos;Fail&apos; &amp;&amp; (max &gt; 0.1 || max &lt; 0.1)) {
                log.info(&quot;🎯 當前 oidx: ${oidx}，max = ${max} (錯誤: max &gt; 0.1 或 max &lt; 0.1)&quot;)

                // 在 debug_max_X 中顯示具體的 oidx 和 max
                def counter = vars.get(&quot;counter_1&quot;) ?: 1
                vars.put(&quot;debug_max_&quot; + counter, &quot;max${counter} = ${max} oidx: ${oidx}&quot;)
            }

            // 計算當前迴圈次數，並生成對應的 max_X 名稱
            def counter = vars.get(&quot;counter_1&quot;) ?: 1  // 獲取計數器，若不存在則預設為 1
            vars.put(&quot;max_&quot; + counter, max.toString())  // 儲存當前迴圈的 max 值

            // 判斷 max 是否異常，若 max &gt; 0.1 或 max &lt; 0.1 時顯示異常提示
            def resultMessage = &quot;max${counter} = ${max}&quot;
            if (max != &apos;Fail&apos; &amp;&amp; (max &gt; 0.1 || max &lt; 0.1)) {
                resultMessage += &quot; 此結果異常&quot;
            }

            // 顯示在 Debug Sampler 中，格式簡潔只顯示 maxXX = XX 或附加異常提示
            vars.put(&quot;debug_max_&quot; + counter, resultMessage)

            // 增加計數器，為下一次迴圈準備
            vars.put(&quot;counter_1&quot;, (counter.toInteger() + 1).toString())  // 更新計數器
        } else {
            log.error(&quot;bet_info not found in response!&quot;)
        }
    }
} catch (Exception e) {
    log.error(&quot;Error in JSR223 script: &quot; + e.getMessage())  // 捕獲並輸出錯誤信息
}























