            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="轉換apikey">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">def pf_id = vars.get(&quot;pf_id&quot;)
def private_key = vars.get(&quot;private key&quot;) // 注意 key 名稱
def timestamp = vars.get(&quot;timestamp&quot;)

log.info(&quot;組合前參數: pf_id=${pf_id}, private_key=${private_key}, timestamp=${timestamp}&quot;)

def raw = &quot;${pf_id}${private_key}${timestamp}&quot;
log.info(&quot;最終拼接字串: &quot; + raw)

import java.security.MessageDigest
MessageDigest digest = MessageDigest.getInstance(&quot;SHA-256&quot;)
byte[] hash = digest.digest(raw.getBytes(&quot;UTF-8&quot;))
def hex = hash.collect { String.format(&quot;%02x&quot;, it) }.join()
vars.put(&quot;api_key&quot;, hex)



</stringProp>
            </JSR223Sampler>
