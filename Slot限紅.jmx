          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="用金鑰轉OTP">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import javax.crypto.Mac
import javax.crypto.spec.SecretKeySpec
import java.nio.ByteBuffer

// 設定你的 Base32 金鑰
def secret = &apos;WBXE7VDDT573552RDOOWTLRWXKEDAP3B&apos;

// Base32 解碼
def base32Decode(String s) {
    def base32Chars = &quot;ABCDEFGHIJKLMNOPQRSTUVWXYZ234567&quot;
    def bits = &quot;&quot;
    s.each { c -&gt;
        def idx = base32Chars.indexOf(c)
        if (idx == -1) {
            throw new IllegalArgumentException(&quot;Invalid Base32 character: ${c}&quot;)
        }
        bits += String.format(&quot;%5s&quot;, Integer.toBinaryString(idx)).replace(&apos; &apos;, &apos;0&apos;)
    }
    def bytes = bits.toList().collate(8).collect { it.join() }
                 .findAll { it.size() == 8 }
                 .collect { Integer.parseInt(it, 2) as byte }
    return bytes as byte[]
}

def decodedKey = base32Decode(secret)

// 根據時間計算 Counter
long timeWindow = System.currentTimeMillis() / 1000 / 30
def data = ByteBuffer.allocate(8).putLong(timeWindow).array()

// 用 HMAC-SHA1 加密
def signKey = new SecretKeySpec(decodedKey, &quot;HmacSHA1&quot;)
def mac = Mac.getInstance(&quot;HmacSHA1&quot;)
mac.init(signKey)
def hash = mac.doFinal(data)

// dynamic truncation 取出 OTP
int offset = hash[-1] &amp; 0x0F
int binary = ((hash[offset] &amp; 0x7F) &lt;&lt; 24) |
             ((hash[offset + 1] &amp; 0xFF) &lt;&lt; 16) |
             ((hash[offset + 2] &amp; 0xFF) &lt;&lt; 8) |
             (hash[offset + 3] &amp; 0xFF)
             
// 取 6 位數
int otp = binary % 1000000
def otpStr = String.format(&quot;%06d&quot;, otp)

// 存到 JMeter 變數
vars.put(&quot;otp&quot;, otpStr)


</stringProp>
          </JSR223Sampler>
