          <hashTree>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper
import java.io.FileOutputStream
import java.io.OutputStreamWriter
import java.io.BufferedWriter
import java.nio.charset.StandardCharsets

// 假設從第一個 API 中篩選的 game_code 存儲在變數 &quot;gameCodes&quot; 中，這部分來自之前的腳本
def gameCodes = vars.get(&quot;3-1gamecode&quot;)?.split(&quot;,&quot;) ?: []

// 需要排除的 OID 清單
def excludedOids = [288, 229, 254, 212, 256, 289, 255]

// 取得第二個 API 回應的內容
def body = prev.getResponseDataAsString()
log.info(&quot;📥 第二個 API 原始回應：\n&quot; + body)

// 解析第二個 API 回應
def json = new JsonSlurper().parseText(body)

// 初始化一個空的陣列來存儲符合條件的 oid
def matchingOids = []

// 確保回應數據存在
if (json?.data) {
    // 遍歷 data，處理每個值
    json.data.each { key, value -&gt;
        if (value instanceof Map) {
            // 取得 game_code 和 oid
            def gameCode = value.game_code
            def oid = value.oid

            // 檢查是否在 gameCodes 中，並且不在排除的 OID 清單中，將符合條件的 oid 加入陣列
            if (gameCodes.contains(gameCode) &amp;&amp; !excludedOids.contains(oid)) {
                matchingOids.add(oid)
            }
        }
    }
} else {
    log.info(&quot;🎯 第二個 API 回應中的 data 為空或未找到。&quot;)
}

// 計算符合條件的 OID 總數
def totalOids = matchingOids.size()

// 將符合條件的 OID 陣列轉為字串，並將其存入 JMeter 變數
def oidsString = matchingOids.join(&quot;,&quot;)
vars.put(&quot;oids&quot;, oidsString)  // 將結果存入 JMeter 變數

// 儲存符合條件的 OID 數量到 oid_count 變數
vars.put(&quot;oid_count&quot;, totalOids.toString())  // 將總數儲存到 JMeter 變數 oid_count

// 輸出符合條件的所有 oid 以及總數
log.info(&quot;🎯 符合條件的 OID 共 ${totalOids} 個，OID: &quot; + oidsString)

// 創建或打開 CSV 文件，並指定編碼為適合 Excel 讀取的格式
def filePath = &quot;C:/apache-jmeter-5.6.3/auto/data/oid.csv&quot;
def file = new File(filePath)

// 打開文件並設置編碼為 UTF-8（不帶 BOM）
FileOutputStream fos = new FileOutputStream(file, false)  // false 表示覆蓋文件
OutputStreamWriter osw = new OutputStreamWriter(fos, StandardCharsets.UTF_8)
BufferedWriter bw = new BufferedWriter(osw)

// 寫入標頭
bw.write(&quot;oid\n&quot;)

// 寫入每個 OID，並確保它們在不同的行中
matchingOids.each {
    bw.write(&quot;${it}\n&quot;)  // 每個 OID 寫入一行
}

// 關閉 BufferedWriter
bw.close()

log.info(&quot;OID 已經成功寫入 ${filePath}&quot;)





</stringProp>
            </JSR223PostProcessor>
