            <hashTree>
              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">import groovy.json.JsonSlurper  // 引入 JsonSlurper 類

try {
    // 獲取當前請求的回應內容
    def body = prev.getResponseDataAsString()  // 使用 prev.getResponseDataAsString() 來獲取 body

    // 檢查 body 是否為 null 或空
    if (body == null || body.trim().isEmpty()) {
        log.error(&quot;Response body is empty!&quot;)
    } else {
        log.info(&quot;Response body: &quot; + body)  // 打印 response body，方便調試

        // 解析 JSON 內容
        def json = new JsonSlurper().parseText(body)

        // 儲存符合條件的 game_code 列表
        def gameCodes = []
        
        // 遍歷 data 中的每個遊戲項目
        json.data.each { game -&gt;
            // 檢查 game_type 是否為 2
            if (game.game_type == &apos;2&apos;) {
                // 儲存符合條件的 game_code
                gameCodes.add(game.game_code)
            }
        }

        // 打印符合條件的 game_code
        log.info(&quot;Filtered game_codes: &quot; + gameCodes)

        // 將 game_code 儲存為 JMeter 變數 3-1gamecode（逗號分隔的字串）
        if (gameCodes.size() &gt; 0) {
            def gameCodeArray = gameCodes.join(&quot;,&quot;)  // 將 game_codes 列表轉換為逗號分隔的字串
            vars.put(&quot;3-1gamecode&quot;, gameCodeArray)  // 儲存為變數
            log.info(&quot;Stored 3-1gamecode = &quot; + gameCodeArray)
        } else {
            log.error(&quot;No game_codes found with game_type = 2&quot;)
        }
    }
} catch (Exception e) {
    log.error(&quot;Error in JSR223 script: &quot; + e.getMessage())  // 捕獲並輸出錯誤信息
}

</stringProp>
